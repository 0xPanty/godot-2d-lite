[gd_scene load_steps=2 format=3]

[ext_resource type="Script" path="res://scripts/runtime_preview.gd" id="1_runtime"]

[node name="RuntimePreview" type="Node2D"]
script = ExtResource("1_runtime")

[node name="World" type="Node2D" parent="."]

[node name="UI" type="CanvasLayer" parent="."]

[node name="Panel" type="PanelContainer" parent="UI"]
offset_left = 24.0
offset_top = 24.0
offset_right = 420.0
offset_bottom = 260.0

[node name="Margin" type="MarginContainer" parent="UI/Panel"]
theme_override_constants/margin_left = 16
theme_override_constants/margin_top = 16
theme_override_constants/margin_right = 16
theme_override_constants/margin_bottom = 16

[node name="VBox" type="VBoxContainer" parent="UI/Panel/Margin"]
layout_mode = 2

[node name="TitleLabel" type="Label" parent="UI/Panel/Margin/VBox"]
layout_mode = 2
text = "运行预览"

[node name="HintLabel" type="Label" parent="UI/Panel/Margin/VBox"]
layout_mode = 2
text = "方向键移动，E 交互，Esc 返回编辑器"

[node name="MessageLabel" type="RichTextLabel" parent="UI/Panel/Margin/VBox"]
custom_minimum_size = Vector2(0, 120)
layout_mode = 2
scroll_active = false
bbcode_enabled = true

[node name="BackButton" type="Button" parent="UI/Panel/Margin/VBox"]
layout_mode = 2
text = "返回编辑器"

[connection signal="pressed" from="UI/Panel/Margin/VBox/BackButton" to="." method="_on_back_button_pressed"]
